#include <stdio.h>
#include <string.h>

int main() {
    int n, i, j, len, metade;
    char texto[1005], aux;

    scanf("%d", &n);
    getchar();

    while (n--) {
        if (fgets(texto, 1005, stdin) == NULL) break;

        len = strlen(texto);
        if (len > 0 && texto[len - 1] == '\n') {
            texto[len - 1] = '\0';
            len--;
        }

        for (i = 0; i < len; i++) {
            if ((texto[i] >= 'A' && texto[i] <= 'Z') || (texto[i] >= 'a' && texto[i] <= 'z')) {
                texto[i] += 3;
            }
        }

        for (i = 0, j = len - 1; i < j; i++, j--) {
            aux = texto[i];
            texto[i] = texto[j];
            texto[j] = aux;
        }

        metade = len / 2;
        for (i = metade; i < len; i++) {
            texto[i] -= 1;
        }

        printf("%s\n", texto);
    }

    return 0;
}
