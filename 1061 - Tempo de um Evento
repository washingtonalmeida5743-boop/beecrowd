#include <stdio.h>

int main() {
    int dia1, h1, m1, s1;
    int dia2, h2, m2, s2;

    char aux[10]; // para ler a palavra "Dia"

    scanf("%s %d", aux, &dia1);
    scanf("%d : %d : %d", &h1, &m1, &s1);

    scanf("%s %d", aux, &dia2);
    scanf("%d : %d : %d", &h2, &m2, &s2);

    int totalSeg1 = s1 + m1*60 + h1*3600 + dia1*86400;
    int totalSeg2 = s2 + m2*60 + h2*3600 + dia2*86400;

    int duracao = totalSeg2 - totalSeg1;

    int W = duracao / 86400;
    duracao %= 86400;

    int X = duracao / 3600;
    duracao %= 3600;

    int Y = duracao / 60;
    int Z = duracao % 60;

    printf("%d dia(s)\n", W);
    printf("%d hora(s)\n", X);
    printf("%d minuto(s)\n", Y);
    printf("%d segundo(s)\n", Z);

    return 0;
}
