#include <stdio.h>

int main() {
    int N;

    while (scanf("%d", &N) != EOF) {
        
        for (int i = 1; i <= N; i += 2) {
            for (int j = 0; j < (N - i) / 2; j++) {
                printf(" ");
            }
            for (int k = 0; k < i; k++) {
                printf("*");
            }
            printf("\n");
        }

        for (int j = 0; j < (N - 1) / 2; j++) {
            printf(" ");
        }
        printf("*\n");

        for (int j = 0; j < (N - 3) / 2; j++) {
            printf(" ");
        }
        printf("***\n");
        
        printf("\n");
    }

    return 0;
}
