#include <stdio.h>

int main() {
int m;
while(1){ 
    scanf("%d", &m);
    if (m == 0){
        break;
    }
    int p[m][m];
for (int i = 0; i < m; i++){
    for(int j = 0; j < m; j++){
        int min = i;
    if (j < min){
        min = j;
    }
    if (m-1 -j < min){
        min = m-1 - j;
    }if (m-1 -i < min){
        min = m-1 - i;
    }
    p[i][j] = min + 1;
    }
}
for (int i = 0; i < m; i++){
    for(int h = 0; h < m; h++){
        if(h == 0){
        printf("%3d", p[i][h]);
        }else {
        printf(" %3d", p[i][h]);
    }
    
    }
printf("\n");
}
printf("\n");

}
return 0;
}
