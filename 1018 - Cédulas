#include <stdio.h>

int main(void) {
    int N, valor;
    scanf("%d", &N);

    valor = N; // guardar o valor original

    printf("%d\n", valor);

    int notas[7] = {100, 50, 20, 10, 5, 2, 1};
    for (int i = 0; i < 7; i++) {
        int qtd = N / notas[i];
        printf("%d nota(s) de R$ %d,00\n", qtd, notas[i]);
        N = N % notas[i];
    }

    return 0;
}
